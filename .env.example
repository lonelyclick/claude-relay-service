HOST=0.0.0.0
PORT=3560
# Use dedicated entrypoints instead of a shared SERVICE_MODE switch:
# `pnpm run start:relay` for public traffic, `pnpm run start:server` for admin/internal traffic.
# Draining lifecycle for rolling restart: readiness flips red immediately, but relay
# can keep accepting new traffic for a short detach grace before the listener closes.
DRAIN_TIMEOUT_MS=30000
DRAIN_POLL_INTERVAL_MS=250
DRAIN_DETACH_GRACE_MS=5000

# Required: protect all /admin endpoints.
ADMIN_TOKEN=replace-with-long-random-token

# Required: Postgres backend for tokens, usage, relay users, session routes & handoffs.
DATABASE_URL=postgres://user:pass@127.0.0.1:5432/claude_oauth_relay

# Required: signs admin UI session cookies. At least 16 bytes.
ADMIN_UI_SESSION_SECRET=replace-with-32-byte-secret
# Required when /internal/ccwebapp or relay private control API is enabled.
INTERNAL_TOKEN=replace-with-long-random-internal-token
# Required for the server process because admin write operations are delegated to relay control API.
# Example: http://127.0.0.1:3560
RELAY_CONTROL_URL=
# Required when using local Better Auth SQL admin/organization operations from the server process.
BETTER_AUTH_DATABASE_URL=
# Better Auth API exposed by cc-webapp production frontend.
BETTER_AUTH_API_URL=https://tokenqiao.com/api/auth

# Optional overrides. Defaults already match current Claude Code prod behavior.
ANTHROPIC_API_BASE_URL=https://api.anthropic.com
OAUTH_AUTHORIZE_URL=https://claude.com/cai/oauth/authorize
OAUTH_TOKEN_URL=https://platform.claude.com/v1/oauth/token
OAUTH_MANUAL_REDIRECT_URL=https://platform.claude.com/oauth/code/callback
OAUTH_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e
OPENAI_CODEX_OAUTH_ISSUER=https://auth.openai.com
OPENAI_CODEX_OAUTH_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
OPENAI_CODEX_OAUTH_REDIRECT_URL=http://localhost:1455/auth/callback
OPENAI_CODEX_API_BASE_URL=https://chatgpt.com/backend-api/codex/v1
OPENAI_CODEX_MODEL=gpt-5-codex

# Google Gemini (OAuth) — uses gemini-cli's installed-app credentials by default.
# These values are fixed by Google to be embedded in client source code; do not
# treat the secret as confidential.
GEMINI_OAUTH_CLIENT_ID=681255809395-oo8ft2oprdrnp9e3aqf6av3hmdib135j.apps.googleusercontent.com
GEMINI_OAUTH_CLIENT_SECRET=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
# Loopback redirect; cor opens an in-process http server on this host:port to
# receive the OAuth callback. Only available when running cor on the same host
# as the browser (set port to 0 to disable).
GEMINI_OAUTH_LOOPBACK_PORT=8085
GEMINI_OAUTH_LOOPBACK_HOST=127.0.0.1
GEMINI_OAUTH_LOOPBACK_REDIRECT_PATH=/oauth/callback
# cloudcode-pa is the same backend gemini-cli uses (Code Assist API).
GEMINI_CODE_ASSIST_ENDPOINT=https://cloudcode-pa.googleapis.com
GEMINI_CODE_ASSIST_API_VERSION=v1internal
GEMINI_DEFAULT_MODEL=gemini-3.1-pro

# Optional networking.
REQUEST_TIMEOUT_MS=30000
API_TIMEOUT_MS=600000
# Default routes relay upstream traffic through local xray.
UPSTREAM_PROXY_URL=http://127.0.0.1:10808
# Set to "direct" to bypass the proxy.
# UPSTREAM_PROXY_URL=direct
# Legacy-compatible alias if you prefer a relay-specific name.
# UPSTREAM_REQUEST_TIMEOUT_MS=600000

# Optional account scheduling.
STICKY_SESSION_TTL_HOURS=1
ACCOUNT_ERROR_COOLDOWN_MS=300000
MIN_CLAUDE_VERSION=2.1.90
DEFAULT_MAX_SESSIONS_PER_ACCOUNT=5
ACCOUNT_MAX_SESSION_OVERFLOW=1
DEFAULT_ACCOUNT_GROUP=default
HEALTH_WINDOW_MS=300000
HEALTH_ERROR_DECAY_THRESHOLD=10
RATE_LIMIT_AUTO_BLOCK_COOLDOWN_MS=900000
# Zero-429 reactive layer: replay the same in-flight request on a fresh account when
# the first account returns 429 / is rate-limited mid-stream. Defaults to true.
# SAME_REQUEST_SESSION_MIGRATION_ENABLED=true

# Max number of same-request retry attempts before surfacing the 429 to the client (0=disabled).
# SAME_REQUEST_MAX_RETRIES=2

# Jitter backoff range between same-request retries (ms).
# SAME_REQUEST_RETRY_BACKOFF_MIN_MS=100
# SAME_REQUEST_RETRY_BACKOFF_MAX_MS=500

# Cooldown durations applied to a rate-limited account after a 429.
# Fallback used when no Retry-After header is present (ms).
# RATE_LIMIT_COOLDOWN_FALLBACK_MS=60000
# Maximum cooldown that can be set from a Retry-After / reset-timestamp header (ms).
# Resets beyond this cap trigger auto_blocked (long_ban) instead of truncating.
# RATE_LIMIT_COOLDOWN_MAX_MS=300000

# Optional relay user / routing guard thresholds. These matter most when DATABASE_URL
# is set and multiple downstream users share the same relay.
ROUTING_USER_MAX_ACTIVE_SESSIONS=12
ROUTING_DEVICE_MAX_ACTIVE_SESSIONS=4
ROUTING_BUDGET_WINDOW_MS=300000
ROUTING_USER_MAX_REQUESTS_PER_WINDOW=300
ROUTING_DEVICE_MAX_REQUESTS_PER_WINDOW=300
ROUTING_USER_MAX_TOKENS_PER_WINDOW=100000000
ROUTING_DEVICE_MAX_TOKENS_PER_WINDOW=100000000
CLAUDE_OFFICIAL_SESSION_ACCOUNT_PINNING=true
# Natural capacity management for Claude official accounts.
# New accounts only receive new sessions; mature accounts receive heavy/cache-heavy sessions.
CLAUDE_OFFICIAL_NATURAL_CAPACITY_ENABLED=true
CLAUDE_OFFICIAL_USER_DEVICE_MAX_ACCOUNTS_24H=3
CLAUDE_OFFICIAL_NEW_ACCOUNT_NEW_SESSION_ONLY_HOURS=72
CLAUDE_OFFICIAL_HEAVY_SESSION_ACCOUNT_MIN_AGE_HOURS=72
CLAUDE_OFFICIAL_HEAVY_SESSION_TOKENS=400000
CLAUDE_OFFICIAL_HEAVY_SESSION_CACHE_READ_TOKENS=300000
DEVICE_AFFINITY_LOOKBACK_HOURS=48
DEVICE_AFFINITY_MIN_SUCCESSES=2
DEVICE_AFFINITY_FAILURE_PENALTY_MS=1800000

# Optional high-risk Feishu alert. Does not block or disable users; it only notifies operators.
# Set this to a Feishu bot webhook URL in production to receive high-risk traffic alerts.
RISK_ALERT_FEISHU_WEBHOOK_URL=
RISK_ALERT_DEDUP_MS=300000
RISK_ALERT_USER_TOKENS_PER_WINDOW=1200000
RISK_ALERT_DEVICE_TOKENS_PER_WINDOW=400000
RISK_ALERT_USER_REQUESTS_PER_WINDOW=60
RISK_ALERT_DEVICE_REQUESTS_PER_WINDOW=20
RISK_ALERT_SESSION_ACCOUNT_SWITCHES_PER_WINDOW=2
RISK_ALERT_USER_ACCOUNTS_PER_WINDOW=2

# When Anthropic returns response header `anthropic-ratelimit-unified-overage-disabled-reason`,
# TokenQiao logs it as an Anthropic risk-watch signal and only cools down warning/rejected cases.
# Plain `org_level_disabled` with `unified-status=allowed` is observation-only.
ANTHROPIC_OVERAGE_DISABLED_GUARD_ENABLED=true
ANTHROPIC_OVERAGE_DISABLED_COOLDOWN_MS=86400000
ANTHROPIC_OVERAGE_ALLOWED_WARNING_COOLDOWN_MS=2700000
ANTHROPIC_OVERAGE_REJECTED_COOLDOWN_MS=14400000
ANTHROPIC_OVERAGE_POLICY_DISABLED_COOLDOWN_MS=86400000
ACCOUNT_RISK_SCORE_REFRESH_ENABLED=true
ACCOUNT_RISK_SCORE_REFRESH_INTERVAL_MS=300000
# When true, the risk-score scheduler removes accounts in the listed bands from
# new-session allocation (existing routes / forceAccountId still bypass).
# Default off — runs in shadow mode for at least a week before you enable.
ACCOUNT_RISK_DEPRIORITIZE_ENABLED=false
ACCOUNT_RISK_DEPRIORITIZE_BANDS=critical

# Optional account keepalive. Keeps paused / soon-expiring accounts warm.
ACCOUNT_KEEPALIVE_ENABLED=true
ACCOUNT_KEEPALIVE_INTERVAL_MS=300000
ACCOUNT_KEEPALIVE_REFRESH_BEFORE_MS=900000
ACCOUNT_KEEPALIVE_FORCE_REFRESH_MS=21600000
# How long quota snapshot data stays fully trusted before blending toward neutral (30 min default).
QUOTA_DATA_FRESHNESS_MS=1800000
# How often keepalive probes stale accounts to refresh rate-limit headers (5 min default).
RATE_LIMIT_PROBE_INTERVAL_MS=300000

# Optional low-volume Claude official account warmup tasks.
# Emits direct lightweight /v1/messages requests, records account_lifecycle_events(event_type=warmup_task),
# and stops per account when risk score / quota status / utilization is unhealthy.
ACCOUNT_WARMUP_TASK_ENABLED=false
ACCOUNT_WARMUP_TASK_INTERVAL_MS=300000
ACCOUNT_WARMUP_TASK_DAILY_MIN=3
ACCOUNT_WARMUP_TASK_DAILY_MAX=6
ACCOUNT_WARMUP_TASK_MIN_GAP_MS=3600000
ACCOUNT_WARMUP_TASK_MAX_ACCOUNTS_PER_TICK=2
ACCOUNT_WARMUP_TASK_MAX_RISK_SCORE=55
ACCOUNT_WARMUP_TASK_MAX_CONNECTED_AGE_HOURS=168
ACCOUNT_WARMUP_TASK_MAX_UTILIZATION=0.65
ACCOUNT_WARMUP_TASK_MAX_TOKENS=128
ACCOUNT_WARMUP_TASK_MODEL=claude-haiku-4-5-20251001
ACCOUNT_WARMUP_TASK_ROUTING_GROUP_IDS=claude-official
# Comma-separated allowlist; e.g. yohomobile.dev. Empty means all email domains.
ACCOUNT_WARMUP_TASK_EMAIL_DOMAINS=

# Claude official account safety guardrails.
# Cache guard protects new accounts from cache_read-heavy spikes; strict affinity avoids soft cross-account session migration.
CLAUDE_NEW_ACCOUNT_CACHE_GUARD_ENABLED=true
CLAUDE_NEW_ACCOUNT_CACHE_GUARD_AGE_HOURS=72
CLAUDE_NEW_ACCOUNT_CACHE_GUARD_WATCH_CACHE_READ_1M=300000
CLAUDE_NEW_ACCOUNT_CACHE_GUARD_CAUTION_CACHE_READ_1M=800000
CLAUDE_NEW_ACCOUNT_CACHE_GUARD_CRITICAL_CACHE_READ_1M=1500000
CLAUDE_NEW_ACCOUNT_CACHE_GUARD_COOLDOWN_MS=1800000
CLAUDE_SESSION_ACCOUNT_AFFINITY_STRICT=true
# 5h utilization threshold above which a sticky session migrates to a less-loaded account (0–1).
STICKY_MIGRATION_5H_UTIL_THRESHOLD=0.75
# Hysteresis margin: migration target must have 5h util below (threshold - hysteresis) to prevent ping-pong.
STICKY_MIGRATION_HYSTERESIS=0.05
# Per-session cooldown between consecutive soft migrations to the same session (ms).
STICKY_MIGRATION_COOLDOWN_MS=300000

# Optional billing display currency. Price rules are stored in micros using this currency.
BILLING_CURRENCY=USD
# Required billing fallback. Covers every Claude Code / ChatGPT model not matched by a more specific rule.
# Values are micros per 1M tokens in BILLING_CURRENCY; defaults are conservative GPT-5-class fallback rates.
BILLING_FALLBACK_INPUT_PRICE_MICROS_PER_MILLION=90000000
BILLING_FALLBACK_OUTPUT_PRICE_MICROS_PER_MILLION=450000000
BILLING_FALLBACK_CACHE_CREATION_PRICE_MICROS_PER_MILLION=112500000
BILLING_FALLBACK_CACHE_READ_PRICE_MICROS_PER_MILLION=9000000

# Optional transactional email. Prefer SES for delivery/bounce/complaint metrics;
# SMTP is a fallback for local Stalwart delivery.
EMAIL_PROVIDER=disabled
EMAIL_FROM=TokenQiao <noreply@tokenqiao.com>
EMAIL_REPLY_TO=support@tokenqiao.com
# EMAIL_PROVIDER=ses
# AWS_SES_REGION=ap-southeast-1
# AWS_SES_ACCESS_KEY_ID=
# AWS_SES_SECRET_ACCESS_KEY=
# AWS_SES_CONFIGURATION_SET=yoho-email-tracking
# EMAIL_PROVIDER=smtp
# SMTP_HOST=mailsg.yohomobile.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=noreply_tokenqiao
# SMTP_PASS=

# Optional admin UI allowlist. Defaults allow Yoho company SSO accounts.
# ADMIN_UI_KEYCLOAK_URL=https://auth.yohomobile.dev
# ADMIN_UI_KEYCLOAK_REALM=yoho
# ADMIN_UI_KEYCLOAK_CLIENT_ID=ccdash
# ADMIN_UI_ALLOWED_EMAIL_DOMAINS=yohomobile.com
# ADMIN_UI_ALLOWED_EMAILS=alice@yohomobile.com,bob@yohomobile.com
# ADMIN_UI_ALLOWED_ORIGINS=https://dash.tokenqiao.com

# Optional deep request diff capture. Intended for temporary debugging only.
RELAY_CAPTURE_ENABLED=false
RELAY_CAPTURE_BODY_MAX_BYTES=512
BODY_REWRITE_SKIP_LOG_ENABLED=false

# Optional VM-level fingerprint template. Keeps machine-identifying headers stable
# when multiple users share one upstream account on this VM.
# VM_FINGERPRINT_TEMPLATE_PATH=./vm-fingerprint.template.json

# Optional body template for normalizing request body to a target version.
# Rewrites system prompt, tools, and cc_version in POST /v1/messages requests.
# BODY_TEMPLATE_PATH=./data/v2.1.98-body-template.json
# BODY_TEMPLATE_NEW_PATH=./data/v2.1.101-body-template.json
