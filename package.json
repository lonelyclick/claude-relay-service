{
  "name": "claude-oauth-relay",
  "version": "0.1.0",
  "private": true,
  "description": "Independent Claude official OAuth relay focused on current Claude Code compatibility.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm --dir web build && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "http-proxy-agent": "^9.0.0",
    "https-proxy-agent": "^9.0.0",
    "pg": "^8.20.0",
    "undici": "^7.8.0",
    "ws": "^8.20.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
